# GitHub token with pull-requests write permission
GITHUB_TOKEN=your_github_token_here

# LLM Provider settings - works with any OpenAI-compatible API
# Examples shown below - fill in whichever provider you use

# NVIDIA NIM (Llama, Mistral, etc.)
LLM_API_KEY=your_nvidia_api_key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct

# OpenAI
# LLM_API_KEY=your_openai_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Groq
# LLM_API_KEY=your_groq_api_key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Together AI
# LLM_API_KEY=your_together_api_key
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf

# Ollama (local)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=codellama
